---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import EventCard from '../components/EventCard.astro';
import eventsData from '../data/events.json';

const allEvents = eventsData.sort((a, b) => new Date(a.date).valueOf() - new Date(b.date).valueOf());

const upcomingEvents = allEvents.filter(event => new Date(event.date) >= new Date());
const pastEvents = allEvents.filter(event => new Date(event.date) < new Date()).reverse();
---

<!doctype html>
<html lang="pl">
	<head>
		<BaseHead title="Kalendarz Wydarzeń - Nadolice Wielkie" description="Wszystkie wydarzenia organizowane w Nadolicach Wielkich" />
	</head>
	<body>
		<Header />
		<main>
			<div class="events-header">
				<h1>Kalendarz Wydarzeń</h1>
				<p class="intro">
					Wszystkie wydarzenia organizowane przez lokalne organizacje w Nadolicach Wielkich
				</p>
				<a href="/zglos-wydarzenie" class="add-event-button">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="12" y1="5" x2="12" y2="19"></line>
						<line x1="5" y1="12" x2="19" y2="12"></line>
					</svg>
					Zgłoś wydarzenie
				</a>
			</div>

			{upcomingEvents.length > 0 && (
				<section class="events-section">
					<h2>Nadchodzące wydarzenia</h2>
					<div class="events-grid">
						{upcomingEvents.map((event) => (
							<EventCard
								title={event.title}
								description={event.description}
								date={event.date}
								time={event.time}
								location={event.location}
								organizer={event.organizer}
								category={event.category}
							/>
						))}
					</div>
				</section>
			)}

			{pastEvents.length > 0 && (
				<section class="events-section past-events">
					<h2>Minione wydarzenia</h2>
					<div class="events-grid">
						{pastEvents.map((event) => (
							<EventCard
								title={event.title}
								description={event.description}
								date={event.date}
								time={event.time}
								location={event.location}
								organizer={event.organizer}
								category={event.category}
							/>
						))}
					</div>
				</section>
			)}

			{upcomingEvents.length === 0 && pastEvents.length === 0 && (
				<div class="no-events">
					<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
						<line x1="16" y1="2" x2="16" y2="6"></line>
						<line x1="8" y1="2" x2="8" y2="6"></line>
						<line x1="3" y1="10" x2="21" y2="10"></line>
					</svg>
					<h2>Brak wydarzeń</h2>
					<p>Aktualnie nie ma żadnych zaplanowanych wydarzeń.</p>
					<a href="/zglos-wydarzenie" class="cta-link">Zgłoś pierwsze wydarzenie</a>
				</div>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
	.events-header {
		text-align: center;
		margin-bottom: 3em;
	}

	.intro {
		font-size: 1.1em;
		color: rgb(var(--gray-dark));
		margin: 1em 0 2em 0;
		line-height: 1.6;
	}

	.add-event-button {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		padding: 0.9em 2em;
		background: var(--accent);
		color: white;
		border-radius: 8px;
		text-decoration: none;
		font-weight: 600;
		transition: all 0.2s ease;
		font-size: 1em;
	}

	.add-event-button:hover {
		background: var(--accent-dark);
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(var(--accent), 0.3);
	}

	.add-event-button svg {
		flex-shrink: 0;
	}

	.events-section {
		margin-bottom: 4em;
	}

	.events-section h2 {
		margin-bottom: 1.5em;
		font-size: 1.8em;
	}

	.past-events {
		opacity: 0.8;
	}

	.past-events h2 {
		color: rgb(var(--gray));
	}

	.events-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(500px, 1fr));
		gap: 1.5em;
	}

	.no-events {
		text-align: center;
		padding: 4em 2em;
		color: rgb(var(--gray));
	}

	.no-events svg {
		margin-bottom: 1em;
		opacity: 0.5;
	}

	.no-events h2 {
		margin: 0 0 0.5em 0;
		color: rgb(var(--gray-dark));
	}

	.no-events p {
		margin: 0 0 1.5em 0;
		font-size: 1.1em;
	}

	.cta-link {
		display: inline-block;
		color: var(--accent);
		text-decoration: none;
		font-weight: 600;
		font-size: 1.1em;
		padding: 0.5em 0;
		border-bottom: 2px solid var(--accent);
		transition: color 0.2s ease;
	}

	.cta-link:hover {
		color: var(--accent-dark);
	}

	@media (max-width: 720px) {
		.events-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
